{
  "info": {
    "name": "GoPortal API",
    "_postman_id": "7a0b6f2f-b3f9-4bd9-8ad9-9f6c52789af0",
    "description": "Auth, profile, and social APIs for Phase 1: Identity & Social.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Create a new user account.\n\nSuccess: 201 User created\nConflict: 409 USERNAME_EXISTS"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Authenticate and receive JWT token.\n\nSuccess: 200 includes data.token\nUnauthorized: 401 BAD_CREDENTIALS"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me"
              ]
            },
            "description": "Get current authenticated user profile."
          }
        },
        {
          "name": "Update Current User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john-updated\"\n}"
            },
            "description": "Update current user profile.\n\nSuccess: 200\nConflict: 409 USERNAME_EXISTS"
          }
        }
      ]
    },
    {
      "name": "Friends",
      "item": [
        {
          "name": "List Friends",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/friends",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "friends"
              ]
            },
            "description": "List accepted friends for current user."
          }
        },
        {
          "name": "Send Friend Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/friends/request",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "friends",
                "request"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"target-user-uuid\"\n}"
            },
            "description": "Send a friend request.\n\nValidation: cannot send to self\nConflict: FRIEND_REQUEST_EXISTS or ALREADY_FRIENDS"
          }
        },
        {
          "name": "Respond Friend Request",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/friends/response",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "friends",
                "response"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requester_id\": \"requester-user-uuid\",\n  \"action\": \"ACCEPT\"\n}"
            },
            "description": "Respond to incoming friend request.\nAction can be ACCEPT or DECLINE."
          }
        },
        {
          "name": "Block User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/friends/block",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "friends",
                "block"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"target-user-uuid\"\n}"
            },
            "description": "Block a user.\n\nValidation: cannot block self"
          }
        }
      ]
    }
  ]
}
