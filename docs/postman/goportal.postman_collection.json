{
  "info": {
    "name": "GoPortal API",
    "_postman_id": "7a0b6f2f-b3f9-4bd9-8ad9-9f6c52789af0",
    "description": "Auth, profile, social, server, channel, messaging, upload, and reaction APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Create a new user account.\n\nSuccess: 201 User created\nConflict: 409 USERNAME_EXISTS"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Authenticate and receive JWT token.\n\nSuccess: 200 includes data.token\nUnauthorized: 401 BAD_CREDENTIALS"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me"
              ]
            },
            "description": "Get current authenticated user profile."
          }
        },
        {
          "name": "Update Current User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john-updated\"\n}"
            },
            "description": "Update current user profile.\n\nSuccess: 200\nConflict: 409 USERNAME_EXISTS"
          }
        }
      ]
    },
    {
      "name": "Friends",
      "item": [
        {
          "name": "List Friends",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/friends",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "friends"
              ]
            },
            "description": "List accepted friends for current user."
          }
        },
        {
          "name": "Send Friend Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/friends/request",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "friends",
                "request"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"target-user-uuid\"\n}"
            },
            "description": "Send a friend request.\n\nValidation: cannot send to self\nConflict: FRIEND_REQUEST_EXISTS or ALREADY_FRIENDS"
          }
        },
        {
          "name": "Respond Friend Request",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/friends/response",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "friends",
                "response"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requester_id\": \"requester-user-uuid\",\n  \"action\": \"ACCEPT\"\n}"
            },
            "description": "Respond to incoming friend request.\nAction can be ACCEPT or DECLINE."
          }
        },
        {
          "name": "Block User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/friends/block",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "friends",
                "block"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"target-user-uuid\"\n}"
            },
            "description": "Block a user.\n\nValidation: cannot block self"
          }
        }
      ]
    },
    {
      "name": "Servers",
      "item": [
        {
          "name": "Create Server",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/servers",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "servers"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Backend Team\"\n}"
            },
            "description": "Create a server (guild).\n\nBusiness rule: creator becomes owner and first member."
          }
        },
        {
          "name": "List Server Members",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/servers/{{server_id}}/members",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "servers",
                "{{server_id}}",
                "members"
              ]
            },
            "description": "List members in a server.\n\nCaller must already be a member."
          }
        },
        {
          "name": "Delete Server (Owner Only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/servers/{{server_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "servers",
                "{{server_id}}"
              ]
            },
            "description": "Delete a server.\n\nOnly owner can delete."
          }
        },
        {
          "name": "Kick Member (Owner Only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/servers/{{server_id}}/members/{{member_user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "servers",
                "{{server_id}}",
                "members",
                "{{member_user_id}}"
              ]
            },
            "description": "Kick a member from server.\n\nOnly owner can kick and owner cannot be kicked."
          }
        },
        {
          "name": "Create Channel In Server",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/servers/{{server_id}}/channels",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "servers",
                "{{server_id}}",
                "channels"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"general\",\n  \"type\": \"TEXT\",\n  \"parent_id\": \"{{category_channel_id}}\",\n  \"position\": 0\n}"
            },
            "description": "Create channel in a server.\n\nSupported types: TEXT, VOICE, CATEGORY."
          }
        }
      ]
    },
    {
      "name": "Channels",
      "item": [
        {
          "name": "Get Channel By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/channels/{{channel_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "channels",
                "{{channel_id}}"
              ]
            },
            "description": "Get channel detail by ID.\n\nCaller must be a member of the channel's server."
          }
        },
        {
          "name": "Update Channel Position",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/channels/{{channel_id}}/position",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "channels",
                "{{channel_id}}",
                "position"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"position\": 2\n}"
            },
            "description": "Update a channel's integer position for sorting."
          }
        }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
          "name": "Upload Attachment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "upload"
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "description": "Upload file attachment. Allowed: image/*, pdf, zip. Max: 10MB."
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "List Channel Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/channels/{{channel_id}}/messages?limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "channels",
                "{{channel_id}}",
                "messages"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Fetch channel messages with pagination."
          }
        },
        {
          "name": "Create Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "messages"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel_id\": \"{{channel_id}}\",\n  \"content_type\": \"text/plain\",\n  \"content\": \"Hello from Postman\",\n  \"encoding\": \"utf-8\",\n  \"is_pinned\": false,\n  \"attachment_ids\": [\n    \"{{attachment_id}}\"\n  ]\n}"
            },
            "description": "Create message and publish Watermill event to chat.message.created."
          }
        },
        {
          "name": "Edit Message",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/messages/{{message_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "messages",
                "{{message_id}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content_type\": \"text/plain\",\n  \"content\": \"edited text\",\n  \"encoding\": \"utf-8\"\n}"
            },
            "description": "Edit message content (author only)."
          }
        },
        {
          "name": "Delete Message",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/messages/{{message_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "messages",
                "{{message_id}}"
              ]
            },
            "description": "Soft-delete a message (author only)."
          }
        },
        {
          "name": "Toggle Reaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/messages/{{message_id}}/reactions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "messages",
                "{{message_id}}",
                "reactions"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emoji\": \"🔥\"\n}"
            },
            "description": "Toggle reaction for current user on target message."
          }
        }
      ]
    }
  ]
}
