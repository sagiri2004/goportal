## STEP 2 — TYPES

### 2a. Extend domain types — do NOT modify `models.ts` directly if only extending

```ts
// packages/types/src/api.ts  ← response/request DTOs go here
export type ApiResponse<T> = {
  success: boolean
  code: string
  message: string
  data: T
}

export type AuthUser = {
  id: string
  username: string
  is_admin: boolean
}

export type LoginResponseData = {
  user: AuthUser
  token: string
}

// Request bodies
export type RegisterRequest = {
  username: string   // min 3 chars
  password: string   // min 6 chars
}

export type LoginRequest = {
  username: string
  password: string
}
```

