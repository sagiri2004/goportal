# Component Patterns

## Standard file structure

```tsx
// 1. React import
import React, { useState, useMemo } from 'react'

// 2. Third-party (lucide icons)
import { Hash, Settings } from 'lucide-react'

// 3. Internal packages — order: ui → types → config → store → services
import { cn } from '@goportal/ui'
import { Button } from '@goportal/ui/components/button'
import type { Channel, User } from '@goportal/types'
import { VOICE_ENABLED } from '@goportal/config'

// 4. Intra-feature imports (relative, same feature)
import { ChannelItem } from './ChannelItem'

// 5. Types
type ComponentProps = {
  items: Channel[]
  activeId: string
  onSelect: (id: string) => void
}

// 6. Component — named export, NEVER default export in packages
export const ComponentName: React.FC<ComponentProps> = ({
  items,
  activeId,
  onSelect,
}) => {
  return (
    <div className={cn('flex flex-col gap-1')}>
      {/* content */}
    </div>
  )
}
```

## Naming conventions

```
Component file:   PascalCase.tsx         → MessageBubble.tsx
Hook file:        camelCase.ts           → useMessages.ts
Store file:       camelCase.store.ts     → chat.store.ts
Repo file:        camelCase.repo.ts      → messages.repo.ts
Type file:        camelCase.ts           → models.ts
Mock file:        camelCase.mock.ts      → messages.mock.ts
Index file:       index.ts              (re-export, no logic)
```

## cn() — always use to combine classes

```tsx
// ✅ CORRECT
className={cn('base-class', isActive && 'active-class', className)}
className={cn('w-full flex items-center gap-2', variant === 'ghost' && 'bg-transparent')}

// ❌ WRONG
className={`base-class ${isActive ? 'active-class' : ''}`}
className={'base-class ' + (isActive ? 'active-class' : '')}
```

## Avatar pattern

```tsx
type AvatarProps = {
  user: Pick<User, 'username' | 'avatarColor'>
  size?: 'sm' | 'md' | 'lg'
}

const sizeClass = { sm: 'w-6 h-6 text-[10px]', md: 'w-8 h-8 text-xs', lg: 'w-10 h-10 text-sm' }

export const UserAvatar: React.FC<AvatarProps> = ({ user, size = 'md' }) => (
  <div
    className={cn('rounded-full flex items-center justify-center font-semibold shrink-0', sizeClass[size])}
    style={{ backgroundColor: user.avatarColor }}
  >
    {user.username[0]?.toUpperCase()}
  </div>
)
```

## Status indicator pattern

```tsx
const STATUS_COLOR: Record<User['status'], string> = {
  online:  'bg-success',
  idle:    'bg-warning',
  dnd:     'bg-danger',
  offline: 'bg-subtle',
}

// Use in component
<div className="relative inline-block">
  <UserAvatar user={user} />
  <span className={cn(
    'absolute bottom-0 right-0 w-3 h-3 rounded-full border-2 border-surface',
    STATUS_COLOR[user.status]
  )} />
</div>
```

## Button patterns — always use Shadcn Button

```tsx
// Primary action
<Button variant="default">Save</Button>

// Secondary / cancel
<Button variant="ghost">Cancel</Button>

// Destructive
<Button variant="destructive">Delete</Button>

// Icon-only button
<Button variant="ghost" size="icon" aria-label="Settings">
  <Settings className="w-4 h-4" />
</Button>

// Full width
<Button variant="default" className="w-full">Log In</Button>

// ❌ Don't create custom buttons
<div onClick={fn} className="bg-primary px-4 rounded">Click</div>
<span onClick={fn}>Click</span>
```

## Input pattern — Shadcn Input + label

```tsx
<div className="space-y-1.5">
  <label className="text-xs font-semibold uppercase tracking-wide text-muted">
    Username
  </label>
  <Input
    placeholder="Enter username"
    value={value}
    onChange={(e) => setValue(e.target.value)}
    className="bg-surface-raised border-white/10 text-foreground placeholder:text-subtle"
  />
</div>
```

## Modal pattern — Shadcn Dialog

```tsx
<Dialog open={isOpen} onOpenChange={setIsOpen}>
  <DialogContent className="bg-surface border-white/10 text-foreground">
    <DialogHeader>
      <DialogTitle>Modal Title</DialogTitle>
    </DialogHeader>
    {/* content */}
    <div className="flex justify-end gap-2 mt-4">
      <Button variant="ghost" onClick={() => setIsOpen(false)}>Cancel</Button>
      <Button onClick={handleConfirm}>Confirm</Button>
    </div>
  </DialogContent>
</Dialog>
```

## Scroll area — always use Shadcn ScrollArea instead of overflow-y-auto

```tsx
import { ScrollArea } from '@goportal/ui/components/scroll-area'

<ScrollArea className="flex-1">
  <div className="px-2 py-3 space-y-1">
    {items.map(item => <Item key={item.id} {...item} />)}
  </div>
</ScrollArea>
```

## Empty state pattern

```tsx
<div className="flex flex-col items-center justify-center h-full gap-3 text-center px-6">
  <Icon className="w-12 h-12 text-subtle" />
  <div className="space-y-1">
    <p className="text-sm font-semibold text-foreground">No messages yet</p>
    <p className="text-xs text-muted">Be the first to say something!</p>
  </div>
</div>
```

## Loading state pattern

```tsx
// Skeleton for message list
<div className="space-y-4 px-4 py-4">
  {Array.from({ length: 5 }).map((_, i) => (
    <div key={i} className="flex items-start gap-3 animate-pulse">
      <div className="w-10 h-10 rounded-full bg-surface-raised shrink-0" />
      <div className="flex-1 space-y-2">
        <div className="h-3 bg-surface-raised rounded w-24" />
        <div className="h-3 bg-surface-raised rounded w-3/4" />
      </div>
    </div>
  ))}
</div>
```

## Feature flag guard

```tsx
import { VOICE_ENABLED } from '@goportal/config'

// If feature is not ready — render placeholder, don't render null
{VOICE_ENABLED ? (
  <VoiceControls />
) : (
  <div className="px-3 py-2 text-xs text-subtle italic">
    Voice — coming soon
  </div>
)}
```

## Anti-patterns — absolute blacklist

```tsx
// ❌ Don't use div as button
<div onClick={fn}>Click me</div>                     // → <button> or <Button>

// ❌ Don't use margin for layout
<div className="mt-4 ml-3">                          // → gap-* in parent flex/grid

// ❌ Don't export default in packages
export default function MyComponent() {}             // → export const MyComponent

// ❌ Don't use any
const handler = (e: any) => {}                       // → specific type

// ❌ Don't create index.tsx in features — only index.ts for re-export
// features/chat/src/index.tsx  ← wrong
// features/chat/src/index.ts   ← correct

// ❌ Don't put business logic in component
// Complex calculation → useMemo or custom hook
// API call → TanStack Query in hook
// Complex state → Zustand store

// ❌ Don't hardcode user-facing strings
<p>Welcome back!</p>      // OK for MVP, but don't hardcode IDs/URLs/keys

// ❌ Don't use console.log in committed code
console.log(data)         // → use logger or delete before commit
```
