## Custom Hook — standard pattern

```ts
// packages/features/chat/src/hooks/useTyping.ts
import { useEffect, useRef } from 'react'
import { socketClient } from '@goportal/services'
import { SOCKET_EVENTS } from '@goportal/types'

export const useTyping = (channelId: string) => {
  const typingRef = useRef(false)

  const startTyping = () => {
    if (typingRef.current) return
    typingRef.current = true
    socketClient.emit(SOCKET_EVENTS.TYPING_START, { channelId })
  }

  const stopTyping = () => {
    typingRef.current = false
    socketClient.emit(SOCKET_EVENTS.TYPING_STOP, { channelId })
  }

  useEffect(() => {
    return () => stopTyping()
  }, [channelId])

  return { startTyping, stopTyping }
}
```

## Feature Flag check

```ts
import { VOICE_ENABLED, THREAD_ENABLED, FILE_UPLOAD_ENABLED } from '@goportal/config'

// packages/config/src/feature-flags.ts
export const VOICE_ENABLED = false          // Enable when LiveKit is ready
export const THREAD_ENABLED = false         // Enable when backend supports it
export const FILE_UPLOAD_ENABLED = true     // Mock upload, can be enabled
```

DO NOT delete disabled feature code. DO NOT comment out code.
Only wrap with flag guard in JSX or `if (!VOICE_ENABLED) return null` in hooks.
