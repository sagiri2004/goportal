# Data, State & Services

## Domain Types — source of truth at `packages/types/models.ts`

```ts
// DO NOT edit this file for UI-only tasks
// DO NOT add temporary fields here
// To extend a type, use intersection type in the feature

type User = {
  id: string
  username: string
  avatarColor: string        // hex, use inline style
  status: 'online' | 'offline' | 'idle' | 'dnd'
}

type Message = {
  id: string
  channelId: string
  authorId: string
  content: string
  timestamp: string          // pre-formatted, render directly
}

type Channel = {
  id: string
  serverId: string
  name: string
  type: 'text' | 'voice'
}

type Server = {
  id: string
  name: string
  initials: string           // 2 characters
}
```

## Mock Data — use existing file, don't create new ones

```ts
// Place mock data at: packages/features/dashboard/mockData.ts
// Import from there — don't create new mock files elsewhere

import {
  mockCurrentUser,
  mockServers,
  mockChannels,
  mockMessages,
  mockUsers,
} from '@goportal/feature-dashboard/mockData'
```

When needing mock data for new features, add to existing `mockData.ts`, don't create a new file.

## Zustand Store — standard pattern

```ts
// packages/store/src/chat.store.ts
import { create } from 'zustand'
import type { Message, Channel } from '@goportal/types'

type ChatState = {
  activeChannelId: string | null
  messages: Record<string, Message[]>   // key = channelId
  setActiveChannel: (id: string) => void
  addMessage: (message: Message) => void
}

export const useChatStore = create<ChatState>((set) => ({
  activeChannelId: null,
  messages: {},

  setActiveChannel: (id) => set({ activeChannelId: id }),

  addMessage: (message) =>
    set((state) => ({
      messages: {
        ...state.messages,
        [message.channelId]: [
          ...(state.messages[message.channelId] ?? []),
          message,
        ],
      },
    })),
}))
```

Each store slice = 1 file:
- `auth.store.ts` — `currentUser`, `token`, `isAuthenticated`
- `chat.store.ts` — `activeChannelId`, `messages`, drafts
- `server.store.ts` — `servers`, `activeServerId`, `channels`
- `ui.store.ts` — `sidebarOpen`, `openModals`, `theme`
- `voice.store.ts` — LiveKit room state (not yet implemented, keep as `{}`)

## TanStack Query — pattern for data fetching

```ts
// packages/features/chat/src/hooks/useMessages.ts
import { useQuery } from '@tanstack/react-query'
import { messagesRepo } from '@goportal/services'

export const useMessages = (channelId: string) =>
  useQuery({
    queryKey: ['messages', channelId],
    queryFn: () => messagesRepo.getByChannel(channelId),
    enabled: !!channelId,
    staleTime: 30_000,
  })
```

When no real API exists, return mock data in repo:

```ts
// packages/services/src/repository/messages.repo.ts
import { mockMessages } from '@goportal/feature-dashboard/mockData'

export const messagesRepo = {
  getByChannel: async (channelId: string) => {
    // TODO: replace with real API call
    return mockMessages.filter(m => m.channelId === channelId)
  },
}
```

## Socket Events — constants at `packages/types/socket-events.ts`

```ts
// When creating new socket event, define the name here first
export const SOCKET_EVENTS = {
  MESSAGE_CREATE:  'message:create',
  MESSAGE_UPDATE:  'message:update',
  MESSAGE_DELETE:  'message:delete',
  TYPING_START:    'typing:start',
  TYPING_STOP:     'typing:stop',
