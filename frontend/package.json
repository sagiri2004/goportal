{
  "name": "goportal-frontend",
  "private": true,
  "packageManager": "npm@10.2.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/features/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=@goportal/web",
    "dev:web:mock": "turbo run dev:mock --filter=@goportal/web",
    "dev:desktop": "turbo run dev --filter=@goportal/desktop",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@goportal/web",
    "build:web:mock": "turbo run build:mock --filter=@goportal/web",
    "build:desktop": "turbo run build --filter=@goportal/desktop",
    "dist:win": "turbo run dist:win --filter=@goportal/desktop",
    "dist:linux": "turbo run dist:linux --filter=@goportal/desktop",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.577.0",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  }
}
