{
  "name": "sagiri-frontend",
  "private": true,
  "packageManager": "npm@10.2.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/features/*"
  ],
  "scripts": {
    "dev:web":       "turbo run dev --filter=@sagiri/web",
    "dev:desktop":   "turbo run dev --filter=@sagiri/desktop",
    "build":         "turbo run build",
    "build:web":     "turbo run build --filter=@sagiri/web",
    "build:desktop": "turbo run build --filter=@sagiri/desktop",
    "typecheck":     "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
