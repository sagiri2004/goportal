PORT=8085
SERVER_ID=notif-node-a
WS_PATH=/ws
WS_PING_INTERVAL=25s
WS_PONG_TIMEOUT=10s
WS_WRITE_TIMEOUT=5s
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
BROKER_DRIVER=rabbitmq
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
TOPIC_NOTIFICATIONS=notification.dispatch.request
TOPIC_DELIVERY_RECEIPT=notification.dispatch.receipt
TOPIC_DLQ=notification.dispatch.dlq
