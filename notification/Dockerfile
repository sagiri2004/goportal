FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/notification-server ./cmd/notification-server

FROM alpine:3.20

RUN apk add --no-cache ca-certificates

COPY --from=builder /bin/notification-server /usr/local/bin/notification-server

EXPOSE 8085

ENTRYPOINT ["/usr/local/bin/notification-server"]
